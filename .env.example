# Netcanon environment configuration
# Copy to .env and adjust values as needed.
# All variables use the NETCANON_ prefix.

# Directory containing device definition YAML files
# NETCANON_DEFINITIONS_DIR=definitions

# Directory where captured configuration files are stored
# NETCANON_CONFIGS_DIR=configs

# Bind address for the Uvicorn server (0.0.0.0 = all interfaces)
# NETCANON_HOST=0.0.0.0

# TCP port for the Uvicorn server
# NETCANON_PORT=8000

# Logging verbosity: debug, info, warning, error, critical
# NETCANON_LOG_LEVEL=info

# Enable "Open in Editor" button (desktop app sets this automatically;
# only enable for local web deployments where the server and browser
# share the same machine).
# NETCANON_OPEN_IN_EDITOR=false

# Max devices processed in parallel within a single backup job.
# Additional devices queue and start as slots free up (FIFO).
# Integer in [1, 10]; hard-capped at 10 to protect target devices
# (most SSH servers cap concurrent sessions between 5 and 16) and
# to bound thread count on the backup server.
# NETCANON_BACKUP_CONCURRENCY=10

# Fernet symmetric key used to encrypt device credentials at rest.
# When set, this takes priority over the OS keyring and any file
# fallback.  Recommended for container / headless / production
# deployments so the key never touches the application's data
# directory.
#
# Generate once with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Inject via your orchestrator's secret-injection mechanism (e.g.
# `docker run -e NETCANON_FERNET_KEY=...`, Kubernetes Secret + envFrom,
# Compose's `secrets:` block, systemd EnvironmentFile, etc).  Format
# is a 44-character urlsafe-base64-encoded string.
#
# Leave unset to fall back to the OS keyring (Windows Credential
# Manager / macOS Keychain / Linux SecretService) — the default for
# desktop installs.  If the keyring backend is also unavailable
# (typical for containers), Netcanon auto-generates a file at
# `$NETCANON_DATA_DIR/.fernet_key` on first use.  See SECURITY.md
# "Credential Storage" for the full resolution chain.
# NETCANON_FERNET_KEY=
